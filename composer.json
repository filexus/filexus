{
  "name": "filexus/filexus",
  "version": "1.0.0",
  "description": "Production-ready Laravel file attachment system for Eloquent models",
  "type": "library",
  "license": "MIT",
  "homepage": "https://github.com/filexus/filexus",
  "support": {
    "issues": "https://github.com/filexus/filexus/issues",
    "source": "https://github.com/filexus/filexus"
  },
  "keywords": [
    "laravel",
    "eloquent",
    "files",
    "uploads",
    "attachments",
    "media"
  ],
  "authors": [
    {
      "name": "John Michael Manlupig",
      "email": "manlupigjohnmichael@gmail.com",
      "homepage": "https://manlupigjohnmichael.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/console": "^11.0|^12.0",
    "illuminate/contracts": "^11.0|^12.0",
    "illuminate/database": "^11.0|^12.0",
    "illuminate/events": "^11.0|^12.0",
    "illuminate/filesystem": "^11.0|^12.0",
    "illuminate/http": "^11.0|^12.0",
    "illuminate/support": "^11.0|^12.0"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0|^10.0",
    "pestphp/pest": "^3.0",
    "pestphp/pest-plugin-laravel": "^3.0",
    "phpstan/phpstan": "^1.10"
  },
  "autoload": {
    "psr-4": {
      "Filexus\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/pest",
    "test-coverage": "/usr/bin/php -d pcov.enabled=1 -d pcov.directory=. vendor/bin/pest --coverage",
    "analyse": "vendor/bin/phpstan analyse --memory-limit=512M"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Filexus\\FilexusServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
